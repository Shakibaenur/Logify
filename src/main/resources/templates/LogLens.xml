<templateSet group="LogLens">

    <!-- ═══════════════════════════════════════════════════════════════════════
         KOTLIN templates (ADVANCED)
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- BASIC -->
    <template name="logt"
              value="private val TAG = &quot;$CLASS_NAME$&quot;"
              description="[LogLens] TAG (class name)">
        <variable name="CLASS_NAME" expression="logClassNameMacro()" alwaysStopAt="false"/>
        <context>
            <option name="KOTLIN_STATEMENT" value="true"/>
            <option name="JAVA_STATEMENT" value="true"/>
        </context>
    </template>

    <template name="logd"
              value="Log.d(&quot;$TAG$&quot;, &quot;$MESSAGE$&quot;$END$)"
              description="[LogLens] Debug log">
        <variable name="TAG" expression="logTagMacro()" alwaysStopAt="false"/>
        <variable name="MESSAGE" expression="smartDefaultMessageMacro()" alwaysStopAt="true"/>
        <context>
            <option name="KOTLIN_STATEMENT" value="true"/>
            <option name="JAVA_STATEMENT" value="true"/>
        </context>
    </template>

    <template name="loge"
              value="Log.e(&quot;$TAG$&quot;, &quot;$MESSAGE$&quot;$END$)">
        <variable name="TAG" expression="logTagMacro()" alwaysStopAt="false"/>
        <variable name="MESSAGE" expression="" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- EMOJI LOGS -->
    <template name="logok"
              value="Log.d(&quot;$TAG$&quot;, &quot;✅ $MESSAGE$&quot;)">
        <variable name="TAG" expression="logTagMacro()" alwaysStopAt="false"/>
        <variable name="MESSAGE" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <template name="logerr"
              value="Log.e(&quot;$TAG$&quot;, &quot;❌ error: $MESSAGE$&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="MESSAGE" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <template name="logdata"
              value="Log.d(&quot;$TAG$&quot;, &quot;📦 $MESSAGE$&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="MESSAGE" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- VARIABLE LOG -->
    <template name="logvar"
              value="Log.d(&quot;$TAG$&quot;, &quot;$VAR$=$$VAR$$&quot;)"
              description="[LogLens] Log nearest variable"
              toReformat="true" toShortenFQNames="true">
        <variable name="TAG" expression="logTagMacro()" defaultValue="&quot;TAG&quot;" alwaysStopAt="false"/>
        <variable name="VAR" expression="nearestVariableMacro()" defaultValue="&quot;value&quot;" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- PERFORMANCE -->
    <template name="logtime"
              value="val __startTime = System.currentTimeMillis()
$END$
Log.d(&quot;$TAG$&quot;, &quot;⏱️ took ${System.currentTimeMillis() - __startTime}ms&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- TRY CATCH -->
    <template name="logtry"
              value="try {
    $END$
} catch (e: Exception) {
    Log.e(&quot;$TAG$&quot;, &quot;❌ error: ${e.message}&quot;, e)
}">
        <variable name="TAG" expression="logTagMacro()"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- FLOW -->
    <template name="logflow"
              value="Log.d(&quot;$TAG$&quot;, &quot;🌊 flow thread=${Thread.currentThread().name}&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- API -->
    <template name="logapi"
              value="Log.d(&quot;$TAG$&quot;, buildString {
    appendLine(&quot;🌐 API CALL&quot;)
    appendLine(&quot;➡️ REQUEST: $REQ$&quot;)
    appendLine(&quot;📦 BODY: $BODY$&quot;)
    appendLine(&quot;✅ RESPONSE: $RES$&quot;)
})">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="REQ" alwaysStopAt="true"/>
        <variable name="BODY" alwaysStopAt="true"/>
        <variable name="RES" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- NAVIGATION -->
    <template name="lognavto"
              value="Log.d(&quot;$TAG$&quot;, &quot;🧭 navigating to: $DEST$&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="DEST" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- AUTH -->
    <template name="loglogin"
              value="Log.d(&quot;$TAG$&quot;, &quot;🔐 login user=$USER$&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="USER" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

    <!-- DATABASE -->
    <template name="logquery"
              value="Log.d(&quot;$TAG$&quot;, &quot;🗄️ QUERY: $QUERY$&quot;)">
        <variable name="TAG" expression="logTagMacro()"/>
        <variable name="QUERY" alwaysStopAt="true"/>
        <context>
        <option name="KOTLIN_STATEMENT" value="true"/>
        <option name="JAVA_STATEMENT" value="true"/>
    </context>
    </template>

</templateSet>